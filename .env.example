PORT=3000
CORS_ORIGINS=*

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/document_intelligence?schema=public

REDIS_URL=redis://localhost:6379

EXTRACTION_ENGINE=mock

OPENAI_API_KEY=

LANGFLOW_BASE_URL=http://localhost:7860/api/v1
LANGFLOW_API_KEY=
# Optional: if set, used directly. If absent, LangFlowSetupService auto-discovers
# or creates the flow from langflow/flows/invoice-extraction.json on first startup.
LANGFLOW_FLOW_ID=
LANGFLOW_TIMEOUT_MS=30000

S3_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=document-intelligence
S3_PREFIX=documents
S3_FORCE_PATH_STYLE=true

MAX_UPLOAD_SIZE_BYTES=5242880

THROTTLE_TTL=60000
THROTTLE_LIMIT=60

FAILED_JOB_RETRY_BASE_MS=300000
MAX_SCHEDULER_RETRIES=3

SHUTDOWN_TIMEOUT_MS=8000

# ─── Docker Compose Port Overrides ───────────────────────────────────────────
API_PORT=3000
POSTGRES_PORT=5432
POSTGRES_DB=document_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_PORT=6379
LANGFLOW_PORT=7860
LOCALSTACK_PORT=4566
LOCALSTACK_SERVICES=s3
LOCALSTACK_DEBUG=0
LOCALSTACK_VOLUME_DIR=./localstack-volume
